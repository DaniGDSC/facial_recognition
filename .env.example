# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=face_db
PG_USER=admin
PG_PASSWORD=changeme

# Encryption keys (generate with: python -c "import os; print(os.urandom(32).hex())")
# Required for biometric image encryption at rest
BIOMETRIC_ENCRYPTION_KEY=
# Required for embedding vector integrity verification
EMBEDDING_HMAC_KEY=

# Session management (generate with: python -c "import os; print(os.urandom(32).hex())")
SESSION_SECRET_KEY=

# Optional overrides
# DATABASE_FILE=/path/to/metadata.db
# ENROLLED_FACES_DIR=/path/to/enrolled_faces
